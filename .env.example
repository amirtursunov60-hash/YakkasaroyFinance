# Шаблон переменных окружения. Скопируйте в .env (он в .gitignore) и заполните.
# Значения для прода задаются в панели Vercel, не в коде.

# Supabase: URL проекта и anon-ключ (Dashboard → Settings → API)
VITE_SUPABASE_URL=
VITE_SUPABASE_KEY=

# Мониторинг ошибок (Sentry). Пусто — мониторинг выключен, приложение работает как обычно.
VITE_SENTRY_DSN=

# E2E-смоук (npm run test:e2e): адрес приложения и учётка для авторизованного обхода.
# Без E2E_EMAIL/E2E_PASSWORD авторизованная часть смоука пропускается.
E2E_BASE_URL=
E2E_EMAIL=
E2E_PASSWORD=
